# ============================================================
# LIMS OCR - Environment Configuration Template
# Copy to .env and fill in your values
# ============================================================

# OpenAI
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o

# Application
DEBUG=false
LOG_LEVEL=INFO

# Redis (for background job processing)
REDIS_URL=redis://localhost:6379/0

# OCR (set to false to skip OCR for digital PDFs)
OCR_ENABLED=true

# File limits
MAX_UPLOAD_SIZE_MB=100